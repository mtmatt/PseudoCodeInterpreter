import dsa

failures <- 0

list <- LinkedList()
if list.is_empty() != true then failures <- failures + 1
list.append("middle")
list.prepend("front")
list.append("back")
if list.size() != 3 then failures <- failures + 1
if list.get(1) != "front" then failures <- failures + 1
if list.get(2) != "middle" then failures <- failures + 1
if list.get(3) != "back" then failures <- failures + 1
list.set(2, "updated")
if list.get(2) != "updated" then failures <- failures + 1
if list.contains("missing") != false then failures <- failures + 1
if list.pop_front() != "front" then failures <- failures + 1
if list.pop_front() != "updated" then failures <- failures + 1
if list.pop_front() != "back" then failures <- failures + 1
if list.pop_front() != none then failures <- failures + 1
if list.is_empty() != true then failures <- failures + 1

stack <- Stack()
if stack.is_empty() != true then failures <- failures + 1
stack.push(10)
stack.push(20)
if stack.peek() != 20 then failures <- failures + 1
if stack.pop() != 20 then failures <- failures + 1
if stack.pop() != 10 then failures <- failures + 1
if stack.pop() != none then failures <- failures + 1

queue <- Queue()
queue.enqueue(1)
queue.enqueue(2)
queue.enqueue(3)
if queue.dequeue() != 1 then failures <- failures + 1
if queue.front() != 2 then failures <- failures + 1
if queue.size() != 2 then failures <- failures + 1
if queue.dequeue() != 2 then failures <- failures + 1
if queue.dequeue() != 3 then failures <- failures + 1
if queue.dequeue() != none then failures <- failures + 1
if queue.is_empty() != true then failures <- failures + 1

table <- HashTable()
if table.size() != 0 then failures <- failures + 1
table.set("name", "pseudo")
table["count"] <- 2
table["count"] <- table["count"] + 1
if table.get("name") != "pseudo" then failures <- failures + 1
if table["count"] != 3 then failures <- failures + 1
if table.contains("missing") != false then failures <- failures + 1
if table.contains("name") != true then failures <- failures + 1
if table.remove("name") != "pseudo" then failures <- failures + 1
if table.contains("name") != false then failures <- failures + 1
if table.size() != 1 then failures <- failures + 1
table.clear()
if table.is_empty() != true then failures <- failures + 1

tree <- Tree()
tree.insert(8)
tree.insert(3)
tree.insert(10)
tree.insert(1)
tree.insert(6)
tree.insert(3)
if tree.contains(6) != true then failures <- failures + 1
if tree.contains(7) != false then failures <- failures + 1
if tree.min() != 1 then failures <- failures + 1
if tree.max() != 10 then failures <- failures + 1
if tree.size() != 5 then failures <- failures + 1

rb <- RBTree()
rb.insert(10)
rb.insert(5)
rb.insert(15)
rb.insert(3)
rb.insert(7)
rb.insert(12)
rb.insert(18)
rb.insert(7)
if rb.root_color() != "black" then failures <- failures + 1
if rb.contains(7) != true then failures <- failures + 1
if rb.contains(9) != false then failures <- failures + 1
if rb.min() != 3 then failures <- failures + 1
if rb.max() != 18 then failures <- failures + 1
if rb.size() != 7 then failures <- failures + 1
if rb.is_empty() != false then failures <- failures + 1

btree <- BTree(2)
for i <- 1 to 20 do
    btree.insert(i)
btree.insert(10)
if btree.contains(15) != true then failures <- failures + 1
if btree.contains(21) != false then failures <- failures + 1
if btree.min() != 1 then failures <- failures + 1
if btree.max() != 20 then failures <- failures + 1
if btree.size() != 20 then failures <- failures + 1
if btree.height() != 4 then failures <- failures + 1
if btree.is_empty() != false then failures <- failures + 1

dsu <- DSU()
dsu.make_set("a")
dsu.make_set("b")
dsu.make_set("c")
if dsu.connected("a", "c") != false then failures <- failures + 1
dsu.merge("a", "b")
dsu.merge("b", "c")
if dsu.connected("a", "c") != true then failures <- failures + 1
if dsu.find("c") != "a" then failures <- failures + 1
if dsu.size() != 1 then failures <- failures + 1

if failures = 0 then
    print("DSA integration PASS")
else
    print("DSA integration FAIL", failures)
