a <- 7
b <- 3
print(a + b, a - b, a * b, a / b, a % b, a ^ b)
f <- 2.5
print(f + 1, f * 2, f / 0.5, -f)
s <- "hello"
t <- s + " " + "world"
print(t)
print(a = 7, a != 7, a < 3, a > 3, a <= 7, a >= 8)
print(1 and 1, 1 and 0, 0 or 1, 0 or 0, not 0, not 1)
print(1 < 2 and 2 < 3 or 0)
print(-a, +a, --a)
print(int("42") + 1, float("1.5") * 2, string(99) + "!")
print(2 ^ 10, 2 ^ 0.5)
