a <- 15
if a < 10 then
    print("small")
else if a < 20 then
    print("medium")
else
    print("large")

if a > 100 then
    print("never")

total <- 0
for i <- 1 to 10 do
    total <- total + i
print(total)

for i <- 10 to 1 step -2 do
    print(i)

evens <- 0
for i <- 1 to 20 do
    if i % 2 = 1 then
        continue
    if i > 14 then
        break
    evens <- evens + i
print(evens)

i <- 1
while i < 100 do
    i <- i * 3
print(i)

count <- 0
while 1 = 1 do
    count <- count + 1
    if count >= 5 then
        break
print(count)

n <- 1
repeat n <- n + 7 until n > 30
print(n)

for outer <- 1 to 3 do
    for inner <- 1 to 3 do
        if inner = 2 then
            continue
        print(outer * 10 + inner)

x <- 5
for i <- 1 to 3 do
    x <- x + 100
print(x, i)
