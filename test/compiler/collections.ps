arr <- {1, 2, 3}
print(arr)
arr.push(4)
arr.push("five")
print(arr.size(), arr.back())
print(arr[1] + arr[2] + arr[3])
arr[2] <- 20
print(arr)
popped <- arr.pop()
print(popped, arr.size())
arr.insert(1, 99)
print(arr)
removed <- arr.remove(2)
print(removed, arr)
arr.resize(6)
print(arr.size())

m <- {{1, 2}, {3, 4}}
print(m[1][2], m[2][1])
m[2][2] <- 40
print(m)

h <- HashTable()
h["one"] <- 1
h[2] <- "two"
print(h["one"], h[2])
print(h.size())
print(h.contains("one"), h.contains("missing"))
h.remove("one")
print(h.size())
h["k"] <- 10
print(h.keys())

s <- "pseudo"
print(s.size())
print(s[1] + s[6])
total <- 0
for i <- 1 to s.size() do
    total <- total + 1
print(total)
